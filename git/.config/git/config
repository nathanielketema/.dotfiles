[core]
	autocrlf = input
	editor = nvim
	excludesFile = $HOME/.config/git/exclude
    pager = delta
[user]
	name = Nathaniel Ketema
	email = nathanielketema@gmail.com
[init]
	defaultBranch = main
[push]
    default = "current"
    autoSetupRemote = true
[pull]
	rebase = true
[fetch]
    prune = true
[diff]
	tool = nvimdiff
    colormoved = "default"
    colormovedws = "allow-indentation-change"
[difftool]
    prompt = false
[branch]
    sort= "committerdate"
[merge]
    conflictstyle = zdiff3
[advice]
    detachedHead = false
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    dark = true
